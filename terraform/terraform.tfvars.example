# This file shows the shape of a real terraform.tfvars file.
# Your real terraform.tfvars is ignored by git and should never be committed,
# especially when it contains account names, usernames, passwords, or other secrets.

aws_region         = "us-west-1"
project_name       = "sport-analysis"
s3_data_bucket     = "sport-analysis"
lambda_execution_role_name = "dev_lamda"
lambda_timeout     = 300
lambda_memory      = 256
clean_player_stats_layer_arn = "arn:aws:lambda:us-west-1:336392948345:layer:AWSSDKPandas-Python311:26"
snowflake_assume_role_user_arn = "arn:aws:iam::123456789012:user/example-user"
snowflake_external_id = "replace-with-your-snowflake-external-id"
snowflake_layer_arn = "arn:aws:lambda:us-west-1:123456789012:layer:snowflake-connector:1"
snowflake_account  = "your-snowflake-account"
snowflake_password = "your-snowflake-password"
snowflake_user     = "your-snowflake-user"
